# ── Build artifacts ───────────────────────────────────────────────────────────
.next
out
build
coverage

# ── Dependencies (reinstalled inside the image) ────────────────────────────────
node_modules

# ── Local env files (never bake secrets into the image) ───────────────────────
.env
.env.local
.env*.local

# ── Dev / editor files ────────────────────────────────────────────────────────
.DS_Store
*.pem
*.tsbuildinfo
next-env.d.ts
.vercel
.git
.gitignore
.dockerignore

# ── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Local DB files ────────────────────────────────────────────────────────────
prisma/*.db
prisma/*.db-journal

# ── Docs / CI (not needed in image) ───────────────────────────────────────────
README.md
CHANGELOG.md
.github
