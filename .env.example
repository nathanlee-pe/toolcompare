# ══════════════════════════════════════════════════════════════════════════════
# saas-reviews — environment variables
#
# Copy this file to .env and fill in your values.
# Never commit .env — it is already in .gitignore.
#
# Deployment targets:
#   Local dev    → .env (this file, filled in)
#   Docker       → docker-compose.yml reads .env automatically
#   Vercel       → set secrets with: vercel env add <NAME>
#                  reference them in vercel.json as @secret-name
#   Railway DB   → copy DATABASE_URL from Railway dashboard → Variables tab
# ══════════════════════════════════════════════════════════════════════════════


# ── Database ──────────────────────────────────────────────────────────────────
#
# Standard PostgreSQL connection string.
#
# Local Docker (docker-compose.yml default):
#   postgresql://saas_user:saas_password@localhost:5432/saas_reviews
#
# Railway (copy from Dashboard → your Postgres service → Variables → DATABASE_URL):
#   postgresql://<user>:<password>@<host>.railway.app:<port>/railway
#
# Neon / Supabase (connection pooling via pgBouncer — use ?pgbouncer=true):
#   postgresql://<user>:<password>@<host>.neon.tech/saas_reviews?sslmode=require
#
# Vercel secret name: @database-url
DATABASE_URL="postgresql://saas_user:saas_password@localhost:5432/saas_reviews"


# ── Anthropic ─────────────────────────────────────────────────────────────────
#
# Required for the content-generation scripts (generate-review.ts,
# generate-comparison.ts, seed-catalogue.ts). NOT needed at runtime — the
# Next.js app itself never calls the Anthropic API.
#
# Get your key: https://console.anthropic.com/settings/keys
#
# Vercel secret name: @anthropic-api-key
ANTHROPIC_API_KEY="sk-ant-..."


# ── Site identity (public) ────────────────────────────────────────────────────
#
# NEXT_PUBLIC_* vars are baked into the client-side JS bundle at build time.
# After changing them you must rebuild the app.
#
# NEXT_PUBLIC_SITE_URL — canonical origin, no trailing slash.
#   Used for: OG tags, canonical URLs, JSON-LD, sitemap, robots.txt.
#   Must match your actual domain in production.
#
# NEXT_PUBLIC_SITE_NAME — short brand name shown in JSON-LD and <title> tags.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="SaaS Reviews"


# ── Analytics (optional, public) ──────────────────────────────────────────────
#
# NEXT_PUBLIC_GA_ID — Google Analytics 4 measurement ID (G-XXXXXXXXXX).
#   Leave blank to disable GA.
#
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN — your domain registered in Plausible
#   (e.g. "yourdomain.com"). Leave blank to disable.
#   You must also add the Plausible script to app/layout.tsx to activate it.
#
# Vercel secret name (GA): @next-public-ga-id
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""


# ── Affiliate tracking ────────────────────────────────────────────────────────
#
# AFFILIATE_SECRET — used to sign and verify affiliate link payloads.
#   Generate: openssl rand -hex 32
#
# CLICK_IP_SALT — mixed into SHA-256 hashes of visitor IPs before storing
#   in ClickLog. Prevents reversing hashes back to raw IPs (GDPR / CCPA).
#   Generate: openssl rand -hex 32
#   Changing this value invalidates all existing hashed IPs (deduplication
#   will break for past clicks, but no data is lost).
#
# Vercel secret names: @affiliate-secret, @click-ip-salt
AFFILIATE_SECRET="replace-with-openssl-rand-hex-32"
CLICK_IP_SALT="replace-with-openssl-rand-hex-32"


# ── Google AdSense ────────────────────────────────────────────────────────────
#
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID — your publisher ID from the AdSense dashboard.
#   Format: "ca-pub-XXXXXXXXXXXXXXXXX"
#   If this variable is not set, all AdSenseUnit components render nothing —
#   safe for development and staging environments.
#
# NEXT_PUBLIC_ADSENSE_SLOT_* — ad unit slot IDs (the number shown in AdSense
#   under Ads → By ad unit). Create one slot per placement:
#     TOOL_BANNER    — horizontal banner on tool review pages (after pros/cons)
#     COMPARE_BANNER — horizontal banner on comparison pages (below table)
#     CATEGORY_MID   — mid-content unit on category listing pages (after 3rd card)
#
# Important: do NOT enable AdSense auto-ads AND manual units on the same page —
# pick one approach per page. Manual units give more layout control and are
# better for programmatic SEO sites where density matters.
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=""
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_BANNER=""
NEXT_PUBLIC_ADSENSE_SLOT_COMPARE_BANNER=""
NEXT_PUBLIC_ADSENSE_SLOT_CATEGORY_MID=""


# ── Email capture ──────────────────────────────────────────────────────────────
#
# Uncomment the block for whichever email provider you use.
# See app/api/subscribe/route.ts for where these are consumed.
#
# Mailchimp
# MAILCHIMP_API_KEY=""      # format: xxxxxxxx-us21
# MAILCHIMP_LIST_ID=""      # your audience ID
#
# ConvertKit / Kit
# CONVERTKIT_API_KEY=""
# CONVERTKIT_FORM_ID=""
#
# Brevo (formerly Sendinblue)
# BREVO_API_KEY=""
# BREVO_LIST_ID=""          # integer


# ── On-demand ISR revalidation ────────────────────────────────────────────────
#
# Used by /api/revalidate to authenticate cache-purge requests.
# Pass this as a Bearer token or ?secret= query param.
# Also referenced by the Vercel cron job in vercel.json.
#
# Generate: openssl rand -hex 32
#
# Vercel secret name: @revalidation-secret
REVALIDATION_SECRET="replace-with-openssl-rand-hex-32"
